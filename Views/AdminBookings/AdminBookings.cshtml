@model IEnumerable<ResturantPG_MVC.ViewModel.BookingVM>

@{
    ViewData["Title"] = "Admin Bokningar - Restaurang PG";
    Layout = "_Layout";
}

@section HeadContent {
    <meta name="description" content="Administratörsgränssnitt för att se och hantera restaurangens bokningar.">
    <meta name="robots" content="noindex, nofollow" />
}

<div class="container mt-5">
    <h2 class="text-primary mb-4">📖 Alla bokningar</h2>

    @if (!Model.Any())
    {
        <div class="alert alert-info">Det finns inga bokningar ännu.</div>
    }
    else
    {
        <ul class="list-group shadow-sm">
            @foreach (var booking in Model)
            {
                <li class="list-group-item d-flex justify-content-between align-items-start flex-column flex-md-row">

                    <div class="me-auto d-flex flex-column flex-sm-row gap-3">
                        <div>

                        </div>
                        <div>
                            <div class="fw-bold">@booking.Guest.Name @booking.Guest.LastName</div>
                            <div class="text-muted">@booking.Guest.Email</div>
                            <div>📞 @booking.Guest.Tel</div>
                            <div>⏰ @booking.BookingStart.ToString("yyyy-MM-dd HH:mm")</div>
                            <div>👥 @booking.NumberOfGuests gäster</div>
                            <div>
                                🪑
                                <span class="badge bg-primary fs-6 px-3 py-2">
                                    Bord Nr @booking.Table?.Number
                                </span>
                                <span class="text-muted ms-2">
                                    (@booking.Table?.Capacity platser)
                                </span>
                            </div>



                        </div>
                        <div class="text-end mb-3">
                            <a asp-controller="AdminTables" asp-action="AdminTables"
                               class="btn btn-outline-info">
                                🪑 Se alla bord
                            </a>
                        </div>

                    </div>

                    <div class="d-flex gap-2 mt-3 mt-md-0 flex-wrap">
                        <a asp-controller="AdminBookings" asp-action="AdminUpdateBooking" asp-route-id="@booking.Booking_Id"
                           class="btn btn-warning btn-sm text-white flex-fill">
                            ✏️ Uppdatera
                        </a>
                        <a href="#"
                           class="btn btn-danger btn-sm text-white flex-fill"
                           data-bs-toggle="modal"
                           data-bs-target="#deleteModal-@booking.Booking_Id">
                            🗑️ Ta bort
                        </a>

                        @* Popup för borttagning *@
                        <div class="modal fade" id="deleteModal-@booking.Booking_Id" tabindex="-1" aria-labelledby="deleteModalLabel-@booking.Booking_Id" aria-hidden="true">
                            <div class="modal-dialog modal-dialog-centered">
                                <div class="modal-content">
                                    <div class="modal-header bg-danger text-white">
                                        <h5 class="modal-title" id="deleteModalLabel-@booking.Booking_Id">Bekräfta borttagning</h5>

                                        <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Stäng"></button>
                                    </div>
                                    <div class="modal-body">
                                        Är du säker på att du vill ta bort bokningen för <strong>@booking.Guest.Name @booking.Guest.LastName</strong>
                                        (⏰ @booking.BookingStart.ToString("yyyy-MM-dd HH:mm"))?
                                    </div>
                                    <div class="modal-footer">
                                        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Avbryt</button>
                                        <a asp-action="DeleteBooking" asp-route-id="@booking.Booking_Id" class="btn btn-danger">🗑️ Ta bort</a>
                                    </div>
                                </div>
                            </div>
                        </div>

                    </div>
                </li>
            }
        </ul>
    }
    <li class="list-group-item text-center">
        <a asp-controller="AdminBookings" asp-action="AdminCreateBooking"
           class="btn add-dish-btn btn-lg w-100">
            ➕ Skapa ny bokning
        </a>

    </li>
</div>
