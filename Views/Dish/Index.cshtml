@model List<ResturantPG_MVC.Models.Dish>
@using ResturantPG_MVC.Extensions

<div class="container mt-5">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="text-center flex-grow-1 text-primary fw-bold">🍴 Vår meny</h2>

        @if (Context.Session.GetToken() != null)
        {
            <a asp-controller="Dish" asp-action="CreateDish" class="btn btn-primary ms-3">
                ➕ Lägg till maträtt
            </a>
        }
    </div>

    @if (!Model.Any())
    {
        <div class="alert alert-warning text-center">
            <p>😔 Hittade inte menyn. Testa igen senare!</p>
        </div>
    }
    else
    {
        <div class="row g-4">
            @foreach (var dish in Model)
            {
                <div class="col-md-4">
                    <div class="card shadow-sm h-100">
                        <img src="@(string.IsNullOrEmpty(dish.PictureUrl)
                                ? "https://images.unsplash.com/photo-1504754524776-8f4f37790ca0"
                                : dish.PictureUrl)"
                                class="card-img-top"
                                alt="@dish.Name"
                                style="height:200px; object-fit:cover;" 
                          />

                        <div class="card-body d-flex flex-column">
                            <h5 class="card-title">@dish.Name</h5>
                            <p class="card-text text-muted">@dish.Description</p>
                            <div class="mt-auto">
                                <span class="badge bg-primary fs-6">@dish.Price kr</span>
                            </div>
                        </div>
                    </div>
                </div>
                }
        </div>
    }
</div>
