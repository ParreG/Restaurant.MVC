@using ResturantPG_MVC.ViewModel
@model CreateDishVM

<div class="container mt-5" style="max-width:600px;">
    <h2 class="mb-4 text-center text-primary fw-bold">🍽️ Skapa ny maträtt</h2>

    <form method="post" asp-action="CreateDish" class="needs-validation" novalidate>

        <!-- Namn -->
        <div class="form-floating-outlined mb-4">
            <input asp-for="Name" class="form-control" placeholder=" " />
            <label asp-for="Name">Maträttens namn</label>
            <span asp-validation-for="Name" class="text-danger"></span>
        </div>

        <!-- Beskrivning -->
        <div class="form-floating-outlined mb-4">
            <textarea asp-for="Description" class="form-control" placeholder=" " style="height:100px"></textarea>
            <label asp-for="Description">Beskrivning</label>
            <span asp-validation-for="Description" class="text-danger"></span>
        </div>

        <!-- Pris -->
        <div class="form-floating-outlined mb-4">
            <input asp-for="Price" type="number" step="0.01" class="form-control" placeholder=" " />
            <label asp-for="Price">Pris (kr)</label>
            <span asp-validation-for="Price" class="text-danger"></span>
        </div>

        <!-- Bild -->
        <div class="form-floating-outlined mb-4">
            <input asp-for="PictureUrl" class="form-control" placeholder=" " />
            <label asp-for="PictureUrl">Bildlänk (valfritt)</label>
            <span asp-validation-for="PictureUrl" class="text-danger"></span>
        </div>

        <div class="d-flex justify-content-between">
            <a asp-controller="Dish" asp-action="Index" class="btn btn-outline-secondary">⬅ Tillbaka</a>
            <button type="submit" class="btn btn-primary">✅ Skapa maträtt</button>
        </div>

        <div class="form-check mb-3">
            <input asp-for="IsPopular" class="form-check-input" type="checkbox" />
            <label asp-for="IsPopular" class="form-check-label">Markera som populär</label>
        </div>

    </form>
</div>
