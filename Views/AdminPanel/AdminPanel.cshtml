@{
    ViewData["Title"] = "Adminpanel";
}

<div class="container mt-5">
    <h2 class="text-center text-primary mb-4">⚙️ Adminpanel</h2>
    <p class="text-center text-muted">Välj en funktion nedan för att administrera restaurangen.</p>

    <div class="row mt-4">
        <div class="col-md-3 mb-3">
            <div class="card shadow-sm border-0 rounded-3 h-100">
                <div class="card-body d-flex flex-column justify-content-between">
                    <h5 class="card-title text-primary">🍽 Hantera rätter</h5>
                    <p class="card-text text-muted">Lägg till, uppdatera eller ta bort maträtter från menyn.</p>
                    <a asp-action="AdminDishes" asp-controller="AdminDishes" class="btn btn-primary w-100 mt-3">Gå till rätter</a>
                </div>
            </div>
        </div>

        <div class="col-md-3 mb-3">
            <div class="card shadow-sm border-0 rounded-3 h-100">
                <div class="card-body d-flex flex-column justify-content-between">
                    <h5 class="card-title text-primary">🪑 Hantera bord</h5>
                    <p class="card-text text-muted">Visa alla bord, uppdatera eller lägg till nya.</p>
                    <a class="btn btn-primary" asp-controller="AdminTables" asp-action="AdminTables">Redigera tables</a>

                </div>
            </div>
        </div>

        <div class="col-md-3 mb-3">
            <div class="card shadow-sm border-0 rounded-3 h-100">
                <div class="card-body d-flex flex-column justify-content-between">
                    <h5 class="card-title text-primary">📅 Hantera bokningar</h5>
                    <p class="card-text text-muted">Lägg till spontanbokning, se alla bokningar, ändra eller ta bort dem.</p>
                    <a asp-action="Bookings" class="btn btn-primary w-100 mt-3">Gå till bokningar</a>
                </div>
            </div>
        </div>

        <div class="col-md-3 mb-3">
            <div class="card shadow-sm border-0 rounded-3 h-100">
                <div class="card-body d-flex flex-column justify-content-between">
                    <h5 class="card-title text-primary">🔑 Admin-inbjudningar</h5>
                    <p class="card-text text-muted">Skapa en inbjudninskod för att bjuda in nya administratörer.</p>
                    <a asp-controller="AdminInvite" asp-action="AdminInvites" class="btn btn-warning w-100 mt-3">Skapa kod</a>
                </div>
            </div>
        </div>
    </div>
</div>
