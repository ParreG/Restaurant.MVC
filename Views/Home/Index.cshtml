@model List<ResturantPG_MVC.Models.Dish>

<!-- Hero-sektion -->
<div class="hero-section text-white text-center d-flex align-items-center justify-content-center"
     style="background-image: url('https://images.unsplash.com/photo-1600891964599-f61ba0e24092?ixlib=rb-4.0.3&auto=format&fit=crop&w=1600&q=80');
            background-size: cover; background-position: center; height: 60vh;">
    <div class="bg-dark bg-opacity-50 p-4 rounded">
        <h1 class="display-3 fw-bold">Välkommen till Restaurang PG</h1>
        <p class="lead">En smakupplevelse för alla – från street food till fine dining</p>
        <div class="mt-3">
            <a asp-controller="Dish" asp-action="Index" class="btn btn-lg btn-primary me-2">🍴 Se vår meny</a>
            <a asp-controller="Booking" asp-action="Index" class="btn btn-lg btn-outline-light">📅 Boka bord</a>
        </div>
    </div>
</div>

<!-- Presentation -->
<div class="container text-center my-5">
    <h2 class="text-primary fw-bold mb-3">Om oss</h2>
    <p class="text-muted fs-5">
        Restaurang PG bjuder på en unik blandning av smaker, från det enkla och rustika till det lyxiga och exklusiva.
        Vårt mål är att ge dig en oförglömlig matupplevelse oavsett om du kommer för en snabb lunch eller en festmiddag.
    </p>
</div>

<!-- Populära rätter -->
<div class="container my-5">
    <h2 class="text-center text-primary fw-bold mb-4">🌟 Populära rätter</h2>

    @if (!Model.Any())
    {
        <div class="alert alert-warning text-center">Inga populära rätter just nu.</div>
    }
    else
    {
        <div class="row g-4">
            @foreach (var dish in Model)
            {
                <div class="col-md-4">
                    <div class="card shadow-sm h-100">
                        <img src="@(string.IsNullOrEmpty(dish.PictureUrl)
                                                         ? "https://images.unsplash.com/photo-1504754524776-8f4f37790ca0"
                                                         : dish.PictureUrl)"
                     class="card-img-top"
                     alt="@dish.Name"
                     style="height:220px; object-fit:cover;" />
                <div class="card-body">
                    <h5 class="card-title">@dish.Name</h5>
                    <p class="card-text text-muted">@dish.Description</p>
                    <span class="badge bg-primary fs-6">@dish.Price kr</span>
                </div>
            </div>
        </div>
                }
        </div>
    }
</div>
